	     ตั้งค่า REVERSED_CLIENT_ID จาก Google Cloud Console เช่น:
	     com.googleusercontent.apps.XXXXXXXX-YYYYYYYYYYYYYYYYYYYYYYY
	     แทนที่ REVERSED_CLIENT_ID ด้านล่างด้วยค่าจริงก่อน build -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.691350048829-2kfhfaao2uq07s64h9f7u0fj4nfnnh00</string>
			</array>
		</dict>
	</array>
